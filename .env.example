# ═══════════════════════════════════════════════════
# PSP Next.js App — Environment Variables
# ═══════════════════════════════════════════════════
# Copy this to .env.local for local dev
# Add all of these to Vercel Environment Variables
# ═══════════════════════════════════════════════════

# ── SUPABASE (Required) ──────────────────────────
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...your-anon-key
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── SITE URL (Required) ──────────────────────────
NEXT_PUBLIC_SITE_URL=https://phillysportspack.com

# ── GOOGLE ANALYTICS (Optional) ──────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── AI FEATURES (Optional — for article summaries/recaps) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── EMAIL (Optional — for newsletter/notifications) ──
RESEND_API_KEY=re_...
