<!--<script data-cfasync="false"
        data-sync="off"
        src="https://cdn.transcend.io/cm/30fbff84-b0e3-4e26-9084-0b5158fdb1ed/airgap.js" onload="window.airgapScriptLoadEvent=event;" defer></script> -->

<script type="text/javascript">
    
    window.airgap = window.airgap || {};

    window.airgap.ready((airgap) => {
        airgap.addEventListener('consent-change', ({ detail: { consent, oldConsent, changes } }) => {
            if (
                oldConsent.purposes['Functional'] == false &&
                consent.purposes['Functional'] == true
            ) {
                airgap.setConsent(window.airgapScriptLoadEvent, {
                    Functional: false,
                });
            }
        });
    }); 

    document.addEventListener("DOMContentLoaded", function () {
        
        if ('airgap' in window && 'transcend' in window) {
            const cpraButton = document.getElementById('cpra_button');
            cpraButton.onclick = (e) => {
                e.preventDefault();
                transcend.showConsentManager({ viewState: 'AcceptAllRejectAllToggle' });
            };

            window.airgap.ready(async (airgap) => {
                //await airgap.sync();
                let userConsent = airgap.getConsent();
                console.info('airgap --> userConsent', userConsent);                
            });
        }
    });


</script>
                    </div>
                </div>
            </footer>
            
            <script>
                require(['jquery', 'headroom', 'jquery-headroom'], function($) {
                    $(function(){
                        $(window).resize(function(){
                            $('html').headroom('destroy').removeData('headroom').headroom({
                                offset: window.matchMedia('(min-width:1025px)').matches ? 96 : 84
                            });
                        }).trigger('resize');
                    });
                    
                    $('.main-header__scoreboard-toggle').click(function(){
                        if ($('html').hasClass('scoreboard-is-open')) {
                            closeScoreboard();
                        } else {
                            openScoreboard();
                        }
                    });
                    
                    window.openScoreboard = function () {
                        $('body').removeClass('mobile-menu-open main-nav');
                        var nav = ko.dataFor($('.c-navigation--main')[0]);
                        nav.closeMenu();
                        nav.data().forEach(function(value, index) {
                            value.closeMenuItem();
                        });
                        $('html').addClass('scoreboard-is-open');
                        $('.main-header__scoreboard-toggle').attr('aria-expanded', 'true');
                    }
                    
                    window.closeScoreboard = function () {
                        $('html').removeClass('scoreboard-is-open');
                        $('.main-header__scoreboard-toggle').attr('aria-expanded', 'false');
                    }
                });
            </script>
            
        </form>
    </body>
</html>